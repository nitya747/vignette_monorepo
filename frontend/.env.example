# Vignette.ai — React Frontend Credentials
# Configure these variables in your local .env or .env.local file.
# If left empty, the application automatically runs in a local sandbox mode,
# keeping it 100% functional with mock logins and session libraries!

# 1. Supabase Web URL (e.g. https://your-project-id.supabase.co)
VITE_SUPABASE_URL=

# 2. Supabase Anon/Public Key (from Settings -> API -> Project API keys)
VITE_SUPABASE_ANON_KEY=
